---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "@/utils/date";
import { getEntry } from "astro:content";
import { getEntries } from "astro:content";
import Link from "@/components/md/Link.astro";
import Img from "@/components/md/Img.astro";
import { Icon } from "astro-icon/components";
import Toast from "@/components/blocks/Toast.astro";
import Comments from "@/components/blocks/Comments.astro";
import TableOfContents from "@/components/blocks/TableOfContents.astro";
import site from "@/config/site";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const category = await getEntry(post.data.category);
const tags = (await getEntries(post.data.tags)).filter((value) => value);
---

<Layout title={post.data.title} description={post.data.summary}>
  <article
    class="animate-in fade-in mx-auto max-w-2xl overflow-x-hidden p-8 duration-1000 md:p-16"
  >
    <header class="mb-16 border-b border-border/50 pb-12">
      <div
        class="mb-6 flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-primary uppercase"
      >
        <a href="/posts" class="hover:underline">Writing</a>
        <span class="text-muted-foreground/30">/</span>
        <!-- <span>Detail</span> -->
        <span>Post</span>
      </div>

      <h1
        class="mb-8 text-3xl leading-[1.4] font-bold text-foreground md:text-4xl"
      >
        {post.data.title}
      </h1>

      <div
        class="animate-in fade-in flex flex-wrap gap-2 font-mono text-[12px] tracking-tight duration-1000 md:gap-3"
      >
        <div
          class="flex items-center gap-3 rounded-full border border-border/40 bg-muted/40 px-3 py-1 text-muted-foreground"
        >
          <div class="flex items-center gap-1.5">
            <Icon name={"mdi:calendar-blank"} />
            <span
              id="post-date"
              data-updated={`${post.data.updatedAt ? "Updated " + formatDate(post.data.updatedAt) : "Not updated"}`}
              >{formatDate(post.data.createdAt)}{
                post.data.updatedAt ? " (edited)" : ""
              }</span
            >
          </div>
          <span class="h-3 w-px bg-border"></span>
          <a
            href={`/categories/${category.data.slug}`}
            class="flex cursor-pointer items-center gap-1.5 transition-colors hover:text-primary"
          >
            <Icon name={"mdi:category-outline"} />
            <span>{category.data.name}</span>
          </a>
        </div>

        <!-- <div
          class="flex items-center gap-4 rounded-full border border-border/20 bg-muted/20 px-3 py-1 text-muted-foreground/60"
        >
          <div class="flex items-center gap-1.5">
            <span class="post-words-count">{post.body?.length} </span>
            <span class="text-[10px] uppercase opacity-90">Words</span>
          </div>

          <div class="flex items-center gap-1.5">
            <span
              class="artalk-pv-count"
              data-page-key={Astro.url.pathname}
              class="font-bold text-foreground/80">-</span
            >
            <span class="text-[10px] uppercase opacity-90">Views</span>
          </div>

          <div class="flex items-center gap-1.5">
            <span
              class="artalk-comment-count"
              data-page-key={Astro.url.pathname}
              class="font-bold text-foreground/80">-</span
            >
            <span class="text-[10px] uppercase opacity-90">Comments</span>
          </div>
        </div> -->
      </div>
    </header>

    <TableOfContents headings={headings} />

    <div
      class:list={[
        "prose max-w-none dark:prose-invert",
        "prose-headings:tracking-tight",
        "prose-p:mb-8 prose-p:leading-loose prose-p:font-normal prose-p:text-muted-foreground",
        "prose-code:rounded-sm prose-code:bg-primary/15 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-primary prose-code:before:content-none prose-code:after:content-none",
        "prose-",
      ]}
      data-pagefind-body
    >
      <Content components={{ a: Link, img: Img }} />
    </div>

    <div
      class="animate-in fade-in mt-12 mb-8 flex flex-wrap gap-2 duration-1000"
    >
      {
        tags.map((tag) => (
          <a
            href={`/tags/${tag.data.slug}`}
            class="group flex items-center gap-1.5 rounded-xl border border-border/50 bg-muted/30 px-3 py-1.5 transition-all hover:border-primary/40 hover:bg-card"
          >
            <span class="font-mono text-xs text-primary/40 italic group-hover:text-primary">
              #
            </span>
            <span class="text-xs font-medium text-muted-foreground transition-colors group-hover:text-foreground">
              {tag.data.name}
            </span>
          </a>
        ))
      }
    </div>
  </article>

  <footer class="mt-16 space-y-12 px-8 md:px-16">
    <div
      class="flex items-center justify-between border-t border-b border-border/50 py-5"
    >
      <a
        href={`/categories/${category.data.slug}`}
        class="group flex items-center gap-2 text-sm text-muted-foreground hover:text-primary"
      >
        <span class="transition-transform group-hover:-translate-x-1">
          <Icon name="mdi:arrow-left" size={14} />
        </span> {site.labels.backToPosts}
      </a>
      <div
        class="font-mono text-[10px] tracking-widest text-muted-foreground/30 uppercase"
      >
        {site.labels.endOfPost}
      </div>
    </div>

    <Toast />
    <Comments />
  </footer>
</Layout>

<style is:global>
  .prose p {
    text-align: justify;
    word-break: break-word;
  }

  .post-words-count,
  .artalk-pv-count,
  .artalk-comment-count {
    color: var(--primary);
    font-weight: 400;
    opacity: 0.8;
  }

  #post-date {
    position: relative;
  }

  #post-date:hover:before {
    position: absolute;
    content: attr(data-updated);
    top: -33px;
    width: fit-content;
    border: 1px solid var(--border);
    border-radius: 2rem;
    text-align: center;
    background-color: var(--muted);
    padding: 2px 4px;
    flex-wrap: nowrap;
    color: var(--muted-foreground);
  }
</style>

